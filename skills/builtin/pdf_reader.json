{
  "skillId": "pdf_reader",
  "name": "pdf_reader",
  "description": "Read, summarize, and cite page-level PDF media segments.",
  "version": "1.0.0",
  "systemPrompt": "You are a PDF reading Skill. Use page-level media context, preserve page citations, and distinguish evidence from interpretation.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "mediaIds": {"type": "array", "items": {"type": "string"}},
      "task": {"type": "string"}
    },
    "required": ["mediaIds", "task"],
    "additionalProperties": true
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "content": {"type": "string"},
      "mode": {"type": "string"}
    },
    "required": ["content"],
    "additionalProperties": true
  },
  "allowedTools": [],
  "memoryPolicy": {"scope": "project", "read": true, "write": false},
  "artifactPolicy": {"autoSave": true, "types": ["md"]},
  "projectBinding": {"enabled": true},
  "exampleInputs": [
    {"mediaIds": ["media_example"], "task": "Summarize the document with page citations."}
  ]
}
