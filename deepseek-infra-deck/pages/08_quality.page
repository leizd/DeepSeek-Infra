pageType: content
background:
  type: solid
  color: "$bg"
elements:
  # ===== 顶部文档轴 =====
  - elementId: header-doc-axis
    elementType: text
    bounds: [48, 16, 300, 14]
    content:
      style: "$headerMeta"
      wrap: false
      align: [left, middle]
      text: DEEPSEEK INFRA
  - elementId: header-page-tag
    elementType: text
    bounds: [612, 16, 300, 14]
    content:
      fontSize: 10
      color: "$gray"
      fontFamily: MiSans
      wrap: false
      align: [right, middle]
      text: 质量 · 08 / 13
  - elementId: header-rule
    elementType: line
    bounds: [48, 44, 864, 2]
    viewBox: [864, 2]
    points: "0,1 864,1"
    border: {style: solid, width: 1, color: "$hairline"}

  # ===== kicker + 页标题 =====
  - elementId: kicker
    elementType: text
    bounds: [48, 60, 400, 16]
    content:
      style: "$kicker"
      wrap: false
      align: [left, middle]
      text: 07 · 质量证据
  - elementId: page-title
    elementType: text
    bounds: [48, 80, 700, 36]
    content:
      style: "$pageTitle"
      wrap: false
      align: [left, middle]
      text: 离线评测，全是 CI 硬门禁

  # ===== 左区：离线基准横向 bar 图 =====
  - elementId: bench-chart-caption
    elementType: text
    bounds: [48, 134, 300, 16]
    content:
      fontSize: 11
      bold: true
      color: "$structure"
      fontFamily: MiSans
      wrap: false
      align: [left, middle]
      text: 离线基准实测（ms）
  # 形状构建的横向条形图（线性刻度 2.15px/ms，零线 x=200）
  - elementId: bench-zero-line
    elementType: line
    bounds: [200, 158, 1, 224]
    viewBox: [1, 224]
    points: "0,0 0,224"
    border: {style: solid, width: 1, color: "$structure"}
  - elementId: bench-label-1
    elementType: text
    bounds: [48, 164, 144, 16]
    content: {fontSize: 11, color: "$ink", fontFamily: MiSans, wrap: false, align: [right, middle], text: 语义缓存 lookup}
  - elementId: bench-bar-1
    elementType: shape
    bounds: [200, 164, 18, 16]
    shapeName: rect
    fill: {type: solid, color: "$structure"}
  - elementId: bench-val-1
    elementType: text
    bounds: [226, 164, 70, 16]
    content: {fontSize: 11, bold: true, color: "$ink", fontFamily: MiSans, wrap: false, align: [left, middle], text: 8.4 ms}
