  # ---- 右侧陶土大斜切（视觉签名，贯穿页高）----
  - elementId: cover-slash
    elementType: shape
    bounds: [780, 0, 120, 540]
    shapeName: parallelogram
    fill: {type: solid, color: "$accent"}
  # ---- 标题区锚点短竖线 ----
  - elementId: cover-anchor
    elementType: shape
    bounds: [48, 210, 4, 62]
    shapeName: rect
    fill: {type: solid, color: "$accent"}
  # ---- 文案区 ----
  - elementId: cover-kicker
    elementType: text
    bounds: [72, 164, 460, 18]
    content:
      style: "$kicker"
      letterSpacing: 3
      wrap: false
      align: [left, middle]
      text: LOCAL-FIRST AGENTIC AI INFRA
  - elementId: cover-title
    elementType: text
    bounds: [72, 204, 620, 74]
    content:
      style: "$display"
      fontSize: 56
      lineHeight: 1.15
      wrap: false
      align: [left, middle]
      text: DeepSeek Infra
  - elementId: cover-subtitle
    elementType: text
    bounds: [72, 292, 480, 24]
    content:
      fontSize: 16
      color: "$structure"
      fontFamily: MiSans
      wrap: false
      align: [left, middle]
      text: 本地优先的 Agentic AI 基础设施平台
  - elementId: cover-lead
    elementType: text
    bounds: [72, 336, 640, 50]
    content:
      fontSize: 13
      color: "$gray"
      fontFamily: MiSans
      lineHeight: 1.6
      align: [left, top]
      text: |
